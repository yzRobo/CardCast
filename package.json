{
  "name": "cardcast",
  "version": "2.0.1",
  "description": "Streaming overlay tool for TCG content creators",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir",
    "rebuild-node": "npm rebuild better-sqlite3",
    "build": "node scripts/build-portable.js",
    "build-portable": "node scripts/build-portable.js",
    "build-seed": "node scripts/build-seed-db.js",
    "test": "node scripts/test-setup.js",
    "setup": "npm install && node scripts/test-setup.js",
    "clean": "rimraf node_modules dist dist-electron data/*.db cache/*",
    "reinstall": "npm run clean && npm install && npm run test",
    "build-css": "tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch",
    "build-css-prod": "tailwindcss -i ./public/css/input.css -o ./public/css/style.css --minify"
  },
  "keywords": [
    "tcg",
    "streaming",
    "overlay",
    "obs",
    "pokemon",
    "magic",
    "yugioh",
    "lorcana",
    "onepiece",
    "digimon",
    "gundam"
  ],
  "author": "",
  "license": "GPL-3.0",
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0-rc.12",
    "csv-parser": "^3.2.0",
    "express": "^4.18.2",
    "socket.io": "^4.6.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "daisyui": "^4.12.10",
    "electron": "^32.2.7",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.0.2",
    "playwright": "^1.61.1",
    "postcss": "^8.5.6",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "com.yzrobo.cardcast",
    "productName": "CardCast",
    "asar": false,
    "files": [
      "**/*",
      "!dist-portable/**",
      "!dist-electron/**",
      "!seed-build/**",
      "!release-assets/**",
      "!data/**",
      "!cache/**",
      "!scripts/**",
      "!*.md",
      "!.env*",
      "!config.local.json",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "release-assets/cardcast-seed.db",
        "to": "cardcast-seed.db"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CardCast-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CardCast"
    },
    "directories": {
      "output": "dist-electron"
    }
  }
}
